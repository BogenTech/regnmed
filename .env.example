# Dev database: `docker compose up -d` or `scripts/dev-db.sh` (no Docker).
DATABASE_URL=postgres://regnmed:regnmed@localhost:5433/regnmed

# OIDC identity provider (networco-id). Required by regnmed-api.
OIDC_ISSUER=https://id.example.com
#OIDC_AUDIENCE=regnmed
# Dev/tests only: load JWKS from a file instead of discovery
# (signatures are still fully validated).
#OIDC_JWKS_FILE=.dev/jwks.json

#BIND_ADDR=127.0.0.1:8080
